# VAPID keys pentru Web Push notifications (Audit #1, 2026-04-23)
#
# GENERARE:
#   node -e "const wp=require('web-push'); const k=wp.generateVAPIDKeys(); console.log(JSON.stringify(k,null,2))"
#
# ADAUGARE IN VERCEL:
#   Dashboard > Livada-Mea > Settings > Environment Variables
#   Scope: Production + Preview + Development
#
# Dupa modificarea variabilelor, trebuie un nou deploy (sau redeploy) ca sa le citeasca.
#
# VAPID_PUBLIC_KEY — public (transmis la frontend, safe)
# VAPID_PRIVATE_KEY — SECRET (doar pe Vercel, niciodata in git/frontend)
# VAPID_CONTACT — email de contact pentru push services (obligatoriu)

VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_CONTACT=mailto:petrilarolly@gmail.com

# Optional — LIVADA_API_TOKEN, deja documentat separat
